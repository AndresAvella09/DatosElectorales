# ══════════════════════════════════════════════════════════════
# DatosElectorales — Variables de Entorno
# ══════════════════════════════════════════════════════════════
# Copia este archivo como .env y completa los valores.
#   cp .env.example .env

# ─── YouTube Scraper ───
# Una o varias keys. El scraper rota cuando una pega quotaExceeded.
# El sufijo numerico define el orden (1 primero, luego 2, 3, ...).
# Saca cada key de: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY1=
YOUTUBE_API_KEY2=
YOUTUBE_API_KEY3=
YOUTUBE_API_KEY4=
# Legacy single-key (vacio: usa las numeradas arriba).
YOUTUBE_API_KEY=

# ─── TikTok Scraper ───
# msToken cookie de tiktok.com. Vacio = se autodetecta del navegador.
# Como sacarla: tiktok.com -> DevTools -> Application -> Cookies -> msToken.
ms_token=
# Tunables opcionales:
# HASHTAG=eleccionescolombia2026
# VIDEO_COUNT=60
# SKIP_KNOWN_VIDEOS=0
# TIKTOK_BROWSER=chromium

# ─── Twitter/X Scraper (Playwright) ───
# Ruta manual al perfil de Edge (opcional, se autodetecta en Windows)
# X_REAL_PROFILE_DIR=
# Nombre del perfil de Edge (opcional)
# X_PROFILE_NAME=
# Nivel de log: DEBUG, INFO, WARNING, ERROR
X_LOG_LEVEL=INFO
# Directorio para artifacts de debug (screenshots, HTML)
# X_DEBUG_DIR=

# ─── Supabase ───
# Project URL: Settings → API → Project URL
SUPABASE_URL=
# anon public key: Settings → API → anon public  (safe para front via RLS)
SUPABASE_ANON_KEY=
# service_role secret: Settings → API → service_role  (¡SECRETO! solo backend/pipeline)
SUPABASE_SERVICE_ROLE_KEY=
# Alias legacy: scrapers viejos leen SUPABASE_KEY. Apuntar a la service_role
# si se quiere activar SUPABASE_LEGACY_SYNC=1.
SUPABASE_KEY=
# Postgres URI: Settings → Database → Connection string → URI
# Usado para aplicar migraciones con psql / supabase CLI.
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ─── General ───
ENVIRONMENT=development
LOG_LEVEL=INFO

# Si =1, los scrapers escriben directo a tablas planas (legacy):
#   tiktok_videos, tiktok_comments, youtube_comments, youtube_videos.
# Default 0: solo CSV en data/inbox/, A2 loaders los promueve a raw/silver/gold.
SUPABASE_LEGACY_SYNC=0
