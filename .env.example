# ══════════════════════════════════════════════════════════════
# DatosElectorales — Variables de Entorno
# ══════════════════════════════════════════════════════════════
# Copia este archivo como .env y completa los valores.
#   cp .env.example .env

# ─── YouTube Scraper ───
YOUTUBE_API_KEY=

# ─── Twitter/X Scraper (Playwright) ───
# Ruta manual al perfil de Edge (opcional, se autodetecta en Windows)
# X_REAL_PROFILE_DIR=
# Nombre del perfil de Edge (opcional)
# X_PROFILE_NAME=
# Nivel de log: DEBUG, INFO, WARNING, ERROR
X_LOG_LEVEL=INFO
# Directorio para artifacts de debug (screenshots, HTML)
# X_DEBUG_DIR=

# ─── Supabase ───
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── General ───
ENVIRONMENT=development
LOG_LEVEL=INFO
